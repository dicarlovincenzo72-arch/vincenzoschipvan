---
const path=Astro.url.pathname;
const links=[['/','Home'],['/schedule','Find Us'],['/menu','Menu'],['/events','Events'],['/gallery','Gallery'],['/awards','Awards'],['/story','Our Story'],['/press','Press'],['/contact','Contact']];
---
<header id="siteHeader" class="header"><div class="bar"><a class="brand" href="/"><img src="/assets/images/logo-original.png" alt="Vincenzo's Fish & Chips Van"></a><button id="menuButton" class="menu" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button><nav id="nav">{links.map(([href,label])=><a class:list={{active:path===href}} href={href}>{label}</a>)}<a class="book" href="/contact">Book Now</a></nav></div></header>
<script is:inline>
const h=document.getElementById('siteHeader'),b=document.getElementById('menuButton'),n=document.getElementById('nav');
b?.addEventListener('click',()=>{const open=n?.classList.toggle('open');b.setAttribute('aria-expanded',String(Boolean(open)));});
n?.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{n.classList.remove('open');b?.setAttribute('aria-expanded','false');}));
const s=()=>h?.classList.toggle('scrolled',scrollY>24);s();addEventListener('scroll',s,{passive:true});
</script>
<style>
.header{position:fixed;inset:0 0 auto;z-index:50;border-bottom:1px solid transparent;transition:.25s}.header.scrolled{background:rgba(10,10,10,.95);border-color:rgba(255,255,255,.11);backdrop-filter:blur(15px)}.bar{width:min(1380px,calc(100% - 48px));min-height:82px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:26px}.brand{width:132px;filter:drop-shadow(0 8px 18px rgba(0,0,0,.42));transition:.25s;flex:0 0 auto}.header.scrolled .brand{width:116px}.brand img{width:100%}nav{display:flex;align-items:center;gap:14px}nav a{color:#fff;font-size:.59rem;font-weight:900;letter-spacing:.075em;text-transform:uppercase;white-space:nowrap}nav a:hover,nav a.active{color:var(--red)}nav .book{padding:12px 17px;border-radius:999px;background:var(--red);color:#fff;box-shadow:0 10px 25px rgba(201,0,34,.24)}.menu{display:none;width:44px;height:44px;border:0;border-radius:50%;background:var(--red)}.menu span{display:block;width:19px;height:2px;margin:4px auto;background:#fff}@media(max-width:1120px){.bar{width:min(100% - 34px,1380px)}.brand{width:122px}nav{gap:10px}nav a{font-size:.54rem}}@media(max-width:920px){.bar{min-height:76px;width:min(100% - 28px,1380px)}.brand,.header.scrolled .brand{width:112px}.menu{display:block}nav{display:none;position:absolute;top:76px;left:14px;right:14px;padding:18px;flex-direction:column;align-items:stretch;background:rgba(12,12,12,.985);border:1px solid rgba(255,255,255,.12);border-radius:18px;box-shadow:0 20px 55px rgba(0,0,0,.35)}nav.open{display:flex}nav a{padding:10px 8px;font-size:.75rem}nav .book{text-align:center}}
</style>
