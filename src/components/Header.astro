---
const path=Astro.url.pathname;
const links=[['/','Home'],['/schedule','Find Us'],['/menu','Menu'],['/events','Events'],['/awards','Awards'],['/press','Press'],['/community','Community'],['/story','About'],['/contact','Contact']];
---
<header id="siteHeader" class="header"><div class="bar"><a class="brand" href="/"><img src="/assets/images/logo-original.png" alt="Vincenzo's Fish & Chips Van"></a><button id="menuButton" class="menu" aria-label="Open menu"><span></span><span></span><span></span></button><nav id="nav">{links.map(([href,label])=><a class:list={{active:path===href}} href={href}>{label}</a>)}<a class="book" href="/contact">Book Now</a></nav></div></header>
<script is:inline>
const h=document.getElementById('siteHeader'),b=document.getElementById('menuButton'),n=document.getElementById('nav');b?.addEventListener('click',()=>n?.classList.toggle('open'));const s=()=>h?.classList.toggle('scrolled',scrollY>24);s();addEventListener('scroll',s,{passive:true});
</script>
<style>
.header{position:fixed;inset:0 0 auto;z-index:50;border-bottom:1px solid transparent;transition:.25s}.header.scrolled{background:rgba(18,18,18,.95);border-color:rgba(255,255,255,.12);backdrop-filter:blur(14px)}.bar{width:min(1440px,calc(100% - 42px));min-height:92px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:25px}.brand{width:218px;filter:drop-shadow(0 8px 18px rgba(0,0,0,.4))}.brand img{width:100%}nav{display:flex;align-items:center;gap:17px}nav a{color:#fff;font-size:.66rem;font-weight:900;letter-spacing:.075em;text-transform:uppercase;white-space:nowrap}nav a:hover,nav a.active{color:var(--red)}nav .book{padding:13px 18px;border-radius:999px;background:var(--red);color:#fff}.menu{display:none;width:46px;height:46px;border:0;border-radius:50%;background:var(--red)}.menu span{display:block;width:20px;height:2px;margin:4px auto;background:#fff}@media(max-width:1100px){.brand{width:180px}nav{gap:12px}nav a{font-size:.6rem}}@media(max-width:920px){.bar{min-height:78px;width:min(100% - 28px,1440px)}.brand{width:160px}.menu{display:block}nav{display:none;position:absolute;top:78px;left:14px;right:14px;padding:18px;flex-direction:column;align-items:stretch;background:rgba(18,18,18,.98);border:1px solid rgba(255,255,255,.12);border-radius:18px}nav.open{display:flex}nav a{padding:10px 8px;font-size:.75rem}nav .book{text-align:center}}
</style>
