---
import BaseLayout from '../layouts/BaseLayout.astro';
const sections = [
['Chip Shop',['Regular Fish','Large Fish','Regular Special Fish','Large Special Fish','Sausage (2)','Smoked Sausage','Hamburger (2)','Steak Pie','King Rib','Haggis Pudding','White Pudding','Black Pudding','Scampi (10)','½ Pizza','Full Pizza','½ Pizza Crunch','Full Pizza Crunch']],
['Extra',['Chicken Nuggets (10)','Chicken Goujons (6)','Onion Rings (10)','Potato Fritters (5)','Fritter Roll']],
['Chips & Sides',['Regular Chips','Large Chips','Chips & Cheese','Chips & Curry','Chips Cheese Curry','Chips & Gravy','Chips Cheese Gravy','Chips & Peas','Chip Roll']],
['Kids',['¼ Pizza & Chips','Nuggets (4) & Chips','Sausage (1) & Chips','Hamburger (1) & Chips']],
['Drinks',['Cans','Water']]
];
---
<BaseLayout title="Menu | Vincenzo's Fish & Chips Van">
<section class="page-hero"><div class="container"><div class="kicker">Freshly cooked</div><h1 class="page-title">Our Menu</h1><p class="lead">Traditional chip-shop favourites cooked fresh from the little black van.</p></div></section>
<section class="section"><div class="container menu-grid">{sections.map(([name,items])=><article class="menu-section card"><h2>{name}</h2><ul>{items.map(item=><li>{item}</li>)}</ul></article>)}</div>
<div class="container dietary"><strong>Dietary information</strong><p>Our food is fried in beef dripping. We do not currently offer gluten-free food because of cross-contamination risk and limited space. White pudding is vegetarian.</p></div></section>
</BaseLayout>
<style>.menu-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}.menu-section{padding:25px}.menu-section h2{color:var(--red);font-size:2rem}.menu-section ul{columns:2;padding-left:20px;line-height:1.8}.dietary{margin-top:24px;padding:24px;background:var(--gold);border-radius:18px}.dietary p{margin-bottom:0;line-height:1.65}@media(max-width:750px){.menu-grid{grid-template-columns:1fr}.menu-section ul{columns:1}}</style>