---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Our Story | Vincenzo's Fish & Chips Van">
<section class="page-hero"><div class="container"><div class="kicker">Vincenzo's</div><h1 class="page-title">Our Story</h1><p class="lead">A dream that began in 2017 and became the little black van.</p></div></section>
<section class="section"><div class="container media-grid"><article class="card placeholder"><h2>Page being rebuilt in Astro</h2><p>This route is active and ready for your real photographs and content.</p></article></div></section>
</BaseLayout>
<style>
.media-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.media-card video{width:100%;aspect-ratio:16/9;object-fit:cover;background:#000}.media-card h2,.placeholder{padding:22px}.placeholder{min-height:260px}@media(max-width:750px){.media-grid{grid-template-columns:1fr}}
</style>