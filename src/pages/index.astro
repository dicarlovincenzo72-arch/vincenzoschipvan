---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Vincenzo's Fish & Chips Van® | Central Scotland" description="Multi award-winning mobile fish and chips across Central Scotland.">
  <section class="hero" aria-label="Vincenzo's Fish & Chips Van">
    <div class="video-stage" aria-hidden="true">
      <video id="heroVideo1" class="hero-video is-active" autoplay muted playsinline preload="auto" poster="/assets/images/press/van-queue.jpg">
        <source src="/assets/videos/doune-gala-main.mp4" type="video/mp4" />
      </video>
      <video id="heroVideo2" class="hero-video" muted playsinline preload="auto" poster="/assets/images/press/van-launch.jpg">
        <source src="/assets/videos/doune-gala-second.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="hero-shade"></div>

    <div class="hero-content container">
      <div class="hero-copy">
        <p class="eyebrow">Vincenzo's Fish & Chips Van®</p>
        <h1>Scotland's multi award-winning <span>mobile fish & chips van</span></h1>
        <p class="lead">Freshly cooked across Central Scotland for village stops, weddings, corporate events, gala days and private celebrations.</p>
        <div class="actions">
          <a class="btn btn-red" href="/schedule">Find Us Today</a>
          <a class="btn btn-outline" href="/contact">Book Your Event</a>
        </div>
        <div class="trust-row" aria-label="Business highlights">
          <span>Multi Award Winning</span>
          <span>Fully Licensed & Insured</span>
          <span>Silent Battery Powered Van</span>
        </div>
      </div>
    </div>

    <div class="video-progress" aria-label="Video progress">
      <button id="videoDot1" class="active" aria-label="Play first video"></button>
      <button id="videoDot2" aria-label="Play second video"></button>
    </div>
    <a class="scroll" href="#discover"><span>Discover</span><i></i></a>
  </section>

  <section id="discover" class="discover">
    <div class="container">
      <div class="intro">
        <p>More than a fish & chips van</p>
        <h2>A little black van with a big story.</h2>
      </div>
      <div class="cards">
        <a href="/awards"><small>01 · Awards & recognition</small><strong>Our Awards</strong><b>→</b></a>
        <a href="/press"><small>02 · Newspapers & television</small><strong>In the Press</strong><b>→</b></a>
        <a href="/community"><small>03 · Charity & local support</small><strong>Our Community</strong><b>→</b></a>
      </div>
    </div>
  </section>

  <section class="feature-band">
    <div class="container feature-grid">
      <div class="feature-copy">
        <p class="section-kicker">Built for memorable events</p>
        <h2>Fresh food, a silent van and service people remember.</h2>
        <p>From village stops and gala days to weddings and corporate catering, every order is cooked fresh from our little black van.</p>
        <a class="text-link" href="/events">Explore events <span>→</span></a>
      </div>
      <div class="feature-image"><img src="/assets/images/press/van-launch.jpg" alt="Vincenzo's Fish & Chips Van at an event" loading="lazy"></div>
    </div>
  </section>

  <section class="home-cta">
    <div class="container cta-inner">
      <div><p class="section-kicker">Find the little black van</p><h2>See where we are serving this week.</h2></div>
      <a class="btn btn-red" href="/schedule">View This Week's Stops</a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const videos = [document.getElementById('heroVideo1'), document.getElementById('heroVideo2')].filter(Boolean);
      const dots = [document.getElementById('videoDot1'), document.getElementById('videoDot2')];
      if (videos.length !== 2) return;

      let current = 0;
      let switching = false;

      videos.forEach((video) => {
        video.muted = true;
        video.playsInline = true;
        video.loop = false;
        video.removeAttribute('loop');
      });

      const setActive = async (index) => {
        if (switching || index === current) return;
        switching = true;
        const outgoing = videos[current];
        const incoming = videos[index];
        try {
          incoming.currentTime = 0;
          await incoming.play();
          incoming.classList.add('is-active');
          outgoing.classList.remove('is-active');
          dots.forEach((dot, i) => dot?.classList.toggle('active', i === index));
          window.setTimeout(() => outgoing.pause(), 850);
          current = index;
        } catch (e) {
          outgoing.play().catch(() => {});
        }
        window.setTimeout(() => { switching = false; }, 900);
      };

      videos[0].addEventListener('ended', () => setActive(1));
      videos[1].addEventListener('ended', () => setActive(0));
      dots[0]?.addEventListener('click', () => setActive(0));
      dots[1]?.addEventListener('click', () => setActive(1));

      videos.forEach((video, index) => {
        video.addEventListener('timeupdate', () => {
          if (index === current && Number.isFinite(video.duration) && video.duration > 0 && video.currentTime >= video.duration - 0.12) {
            setActive(index === 0 ? 1 : 0);
          }
        });
      });

      const start = () => videos[0].play().catch(() => {});
      start();
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) videos[current].play().catch(() => {});
      });
      document.addEventListener('pointerdown', start, { once: true });
    })();
  </script>
</BaseLayout>

<style>
  .hero{position:relative;min-height:100svh;overflow:hidden;background:#080808;color:#fff;border-radius:0 0 22px 22px}
  .video-stage,.hero-video,.hero-shade{position:absolute;inset:0;width:100%;height:100%}
  .hero-video{object-fit:cover;opacity:0;transform:scale(1.01);transition:opacity .8s ease,transform 9s linear;pointer-events:none}
  .hero-video.is-active{opacity:1;transform:scale(1.045)}
  .hero-shade{background:linear-gradient(90deg,rgba(0,0,0,.84) 0%,rgba(0,0,0,.68) 39%,rgba(0,0,0,.30) 70%,rgba(0,0,0,.16) 100%),linear-gradient(0deg,rgba(0,0,0,.72),transparent 56%)}
  .hero-content{position:relative;z-index:2;min-height:100svh;padding-top:132px;padding-bottom:108px;display:flex;align-items:center}
  .hero-copy{width:min(680px,65vw)}
  .eyebrow{margin:0 0 17px;font-size:.7rem;font-weight:900;letter-spacing:.22em;text-transform:uppercase;color:#fff}
  h1{margin:0;max-width:680px;font-size:clamp(3rem,5.35vw,5.6rem);line-height:.92;letter-spacing:-.056em;text-wrap:balance;text-shadow:0 12px 34px rgba(0,0,0,.46)}
  h1 span{display:block;color:#fff;-webkit-text-stroke:1.15px var(--red);text-shadow:0 9px 26px rgba(0,0,0,.55)}
  .lead{max-width:620px;margin:24px 0 0;font-size:clamp(1rem,1.35vw,1.15rem);line-height:1.62;color:rgba(255,255,255,.92)}
  .actions{display:flex;gap:13px;flex-wrap:wrap;margin-top:28px}
  .trust-row{display:flex;gap:9px;flex-wrap:wrap;margin-top:24px}
  .trust-row span{padding:8px 11px;border:1px solid rgba(255,255,255,.22);border-radius:999px;background:rgba(0,0,0,.23);backdrop-filter:blur(8px);font-size:.59rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase;color:rgba(255,255,255,.9)}
  .video-progress{position:absolute;right:32px;bottom:28px;z-index:4;display:flex;gap:8px}
  .video-progress button{appearance:none;border:0;padding:0;width:30px;height:4px;border-radius:999px;background:rgba(255,255,255,.36);transition:.35s;cursor:pointer}
  .video-progress button.active{width:54px;background:var(--red)}
  .scroll{position:absolute;z-index:3;left:50%;bottom:20px;transform:translateX(-50%);display:grid;justify-items:center;gap:8px;color:#fff;font-size:.56rem;font-weight:900;letter-spacing:.18em;text-transform:uppercase}
  .scroll i{width:1px;height:32px;background:#fff;animation:p 1.8s infinite}
  @keyframes p{0%,100%{transform:scaleY(.45);transform-origin:top;opacity:.45}50%{transform:scaleY(1);opacity:1}}
  .discover{padding:96px 0;background:var(--cream)}
  .intro{display:grid;grid-template-columns:.42fr 1fr;gap:60px;align-items:end;margin-bottom:44px}
  .intro p,.section-kicker{margin:0;color:var(--red);font-size:.68rem;font-weight:900;letter-spacing:.16em;text-transform:uppercase}
  .intro h2,.feature-copy h2,.cta-inner h2{margin:0;font-size:clamp(2.45rem,4.5vw,4.65rem);line-height:.97;letter-spacing:-.05em}
  .cards{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .cards a{min-height:156px;padding:27px 24px;display:grid;grid-template-columns:1fr auto;align-content:center;gap:10px;border-right:1px solid var(--line);transition:.25s}
  .cards a:last-child{border-right:0}.cards a:hover{background:var(--charcoal);color:#fff;transform:translateY(-3px)}
  .cards small{grid-column:1/-1;color:#747474;font-size:.67rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.cards strong{font-size:1.4rem}.cards b{color:var(--red);font-size:1.3rem}
  .feature-band{padding:92px 0;background:#111;color:#fff}
  .feature-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:70px;align-items:center}
  .feature-copy h2{margin-top:16px;max-width:580px}.feature-copy>p:not(.section-kicker){max-width:570px;color:rgba(255,255,255,.72);font-size:1.04rem;line-height:1.7}
  .text-link{display:inline-flex;gap:10px;margin-top:16px;font-size:.72rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.text-link span{color:var(--red)}
  .feature-image{overflow:hidden;border-radius:22px;aspect-ratio:16/10}.feature-image img{width:100%;height:100%;object-fit:cover;transition:.45s}.feature-image:hover img{transform:scale(1.025)}
  .home-cta{padding:72px 0;background:var(--cream)}.cta-inner{display:flex;align-items:end;justify-content:space-between;gap:35px}.cta-inner h2{max-width:760px;margin-top:13px;font-size:clamp(2.2rem,4vw,4rem)}
  @media(max-width:980px){.hero-copy{width:min(690px,78vw)}.feature-grid{grid-template-columns:1fr;gap:38px}.cta-inner{align-items:flex-start;flex-direction:column}.intro{grid-template-columns:1fr;gap:12px}.cards{grid-template-columns:1fr}.cards a{border-right:0;border-bottom:1px solid var(--line)}}
  @media(max-width:700px){.hero-content{padding-top:118px;padding-bottom:112px;align-items:flex-end}.hero-copy{width:100%}h1{font-size:clamp(2.85rem,13vw,4.3rem);max-width:100%}.lead{font-size:1rem;line-height:1.55}.actions,.actions .btn{width:100%}.trust-row{display:none}.video-progress{right:18px;bottom:24px}.scroll{display:none}.discover,.feature-band{padding:68px 0}.hero-shade{background:linear-gradient(90deg,rgba(0,0,0,.84),rgba(0,0,0,.40)),linear-gradient(0deg,rgba(0,0,0,.78),transparent 55%)}.feature-image{aspect-ratio:4/3}}
</style>
