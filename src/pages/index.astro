---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Vincenzo's Fish & Chips Van® | Central Scotland" description="Multi award-winning mobile fish and chips across Central Scotland.">
  <main class="home-hero" aria-label="Vincenzo's Fish & Chips Van">
    <div class="video-stage" aria-hidden="true">
      <video id="heroVideo1" class="hero-video is-active" autoplay muted playsinline preload="auto" poster="/assets/images/press/van-queue.jpg">
        <source src="/assets/videos/doune-gala-main.mp4" type="video/mp4" />
      </video>
      <video id="heroVideo2" class="hero-video" muted playsinline preload="auto" poster="/assets/images/press/van-launch.jpg">
        <source src="/assets/videos/doune-gala-second.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="hero-overlay" aria-hidden="true"></div>
    <div id="transitionGlow" class="transition-glow" aria-hidden="true"></div>

    <nav class="quick-actions" aria-label="Quick links">
      <a class="primary" href="/schedule">Find Us Today</a>
      <a href="/menu">Menu</a>
      <a href="/events">Events</a>
    </nav>

    <div class="video-progress" aria-label="Video selection">
      <button id="videoDot1" class="active" aria-label="Play first video"></button>
      <button id="videoDot2" aria-label="Play second video"></button>
    </div>
  </main>

  <script is:inline>
    (() => {
      const videos = [document.getElementById('heroVideo1'), document.getElementById('heroVideo2')].filter(Boolean);
      const dots = [document.getElementById('videoDot1'), document.getElementById('videoDot2')];
      const glow = document.getElementById('transitionGlow');
      if (videos.length !== 2) return;

      let current = 0;
      let switching = false;
      const transitionMs = 1450;

      videos.forEach((video) => {
        video.muted = true;
        video.playsInline = true;
        video.loop = false;
        video.removeAttribute('loop');
      });

      const setActive = async (index) => {
        if (switching || index === current) return;
        switching = true;

        const outgoing = videos[current];
        const incoming = videos[index];

        try {
          incoming.currentTime = 0;
          await incoming.play();

          glow?.classList.remove('run');
          void glow?.offsetWidth;
          glow?.classList.add('run');

          outgoing.classList.add('is-leaving');
          incoming.classList.add('is-active', 'is-entering');
          dots.forEach((dot, i) => dot?.classList.toggle('active', i === index));

          window.setTimeout(() => {
            outgoing.classList.remove('is-active', 'is-leaving');
            outgoing.pause();
            incoming.classList.remove('is-entering');
            current = index;
            switching = false;
          }, transitionMs);
        } catch (error) {
          outgoing.play().catch(() => {});
          switching = false;
        }
      };

      videos.forEach((video, index) => {
        video.addEventListener('timeupdate', () => {
          if (
            index === current &&
            !switching &&
            Number.isFinite(video.duration) &&
            video.duration > 0 &&
            video.currentTime >= video.duration - 1.35
          ) {
            setActive(index === 0 ? 1 : 0);
          }
        });
        video.addEventListener('ended', () => setActive(index === 0 ? 1 : 0));
      });

      dots[0]?.addEventListener('click', () => setActive(0));
      dots[1]?.addEventListener('click', () => setActive(1));

      const resume = () => videos[current].play().catch(() => {});
      resume();
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) resume();
      });
      document.addEventListener('pointerdown', resume, { once: true });
    })();
  </script>
</BaseLayout>

<style>
  :global(body){overflow:hidden}
  .home-hero{position:relative;height:100svh;min-height:620px;overflow:hidden;background:#101010;color:#fff}
  .video-stage,.hero-video,.hero-overlay,.transition-glow{position:absolute;inset:0;width:100%;height:100%}
  .video-stage{z-index:0;background:#111}
  .hero-video{object-fit:cover;opacity:0;transform:scale(1.015);filter:blur(0);transition:opacity 1.45s cubic-bezier(.22,.61,.36,1),transform 8s linear,filter 1.45s ease;pointer-events:none;will-change:opacity,transform,filter}
  .hero-video.is-active{opacity:1;transform:scale(1.065)}
  .hero-video.is-entering{animation:cinematic-in 1.45s cubic-bezier(.22,.61,.36,1) both}
  .hero-video.is-leaving{animation:cinematic-out 1.45s cubic-bezier(.22,.61,.36,1) both}
  @keyframes cinematic-in{0%{opacity:0;transform:scale(1.09);filter:blur(8px) brightness(1.12)}55%{opacity:.72;filter:blur(2px) brightness(1.06)}100%{opacity:1;transform:scale(1.045);filter:blur(0) brightness(1)}}
  @keyframes cinematic-out{0%{opacity:1;transform:scale(1.065);filter:blur(0)}100%{opacity:0;transform:scale(1.025);filter:blur(6px) brightness(.82)}}
  .hero-overlay{z-index:1;background:linear-gradient(180deg,rgba(0,0,0,.18) 0%,rgba(0,0,0,.03) 42%,rgba(0,0,0,.55) 100%),linear-gradient(90deg,rgba(0,0,0,.18),transparent 46%);pointer-events:none}
  .transition-glow{z-index:2;opacity:0;pointer-events:none;background:linear-gradient(105deg,transparent 0%,transparent 38%,rgba(255,255,255,.20) 49%,rgba(255,255,255,.07) 55%,transparent 67%);transform:translateX(-125%)}
  .transition-glow.run{animation:light-sweep 1.45s cubic-bezier(.22,.61,.36,1)}
  @keyframes light-sweep{0%{opacity:0;transform:translateX(-125%)}28%{opacity:.65}100%{opacity:0;transform:translateX(125%)}}
  .quick-actions{position:absolute;z-index:4;left:50%;bottom:34px;transform:translateX(-50%);display:flex;align-items:center;gap:7px;padding:7px;border:1px solid rgba(255,255,255,.24);border-radius:999px;background:rgba(12,12,12,.45);backdrop-filter:blur(16px);box-shadow:0 16px 44px rgba(0,0,0,.30)}
  .quick-actions a{display:flex;align-items:center;justify-content:center;min-height:44px;padding:0 20px;border-radius:999px;color:#fff;font-size:.68rem;font-weight:900;letter-spacing:.09em;text-transform:uppercase;white-space:nowrap;transition:.25s ease}
  .quick-actions a:hover{background:rgba(255,255,255,.14)}
  .quick-actions a.primary{background:var(--red);box-shadow:0 8px 22px rgba(215,0,38,.34)}
  .quick-actions a.primary:hover{transform:translateY(-1px);filter:brightness(1.08)}
  .video-progress{position:absolute;z-index:4;right:28px;bottom:42px;display:flex;align-items:center;gap:8px}
  .video-progress button{appearance:none;border:0;padding:0;width:24px;height:3px;border-radius:999px;background:rgba(255,255,255,.42);cursor:pointer;transition:.35s ease}
  .video-progress button.active{width:48px;background:#fff}
  @media(max-width:760px){
    .home-hero{min-height:560px}
    .hero-video{object-position:center center}
    .hero-overlay{background:linear-gradient(180deg,rgba(0,0,0,.20),transparent 38%,rgba(0,0,0,.66) 100%)}
    .quick-actions{left:14px;right:14px;bottom:20px;transform:none;justify-content:center}
    .quick-actions a{flex:1;padding:0 10px;font-size:.61rem}
    .video-progress{right:18px;bottom:82px}
  }
</style>
